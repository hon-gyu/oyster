{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["ES2020", "DOM"],
    "outFile": "widget.js",
    "removeComments": false,
    "newLine": "lf"
  },
  "files": ["config.d.ts", "widget.ts"]
}
